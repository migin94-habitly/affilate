# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development          # production включает Secure-флаг на cookie

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://tap_user:tap_secret@localhost:5432/tap_db?sslmode=disable

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=tap-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123

# ── Tracking ──────────────────────────────────────────────────────────────────
# Публичный URL, на который указывают трекинговые ссылки (/track/<click_id>)
BASE_REDIRECT_URL=https://ticketon.kz
COOKIE_WINDOW_DAYS=30

# ── Webhook ───────────────────────────────────────────────────────────────────
# Секрет, который Ticketon Core передаёт в поле "secret" каждого webhook-запроса
WEBHOOK_SECRET=change-me-to-a-strong-webhook-secret

# ── Payouts ───────────────────────────────────────────────────────────────────
PAYOUT_MIN_THRESHOLD=5000
PAYOUT_CURRENCY=KZT

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
