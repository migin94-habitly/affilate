# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://tap_user:tap_secret@localhost:5432/tap_db?sslmode=disable

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRY_HOURS=72

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=tap-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
# Set to true when using AWS S3 (not MinIO)
S3_USE_PATH_STYLE=true

# ── Tracking ──────────────────────────────────────────────────────────────────
TRACKING_BASE_URL=https://tap.ticketon.kz
COOKIE_WINDOW_DAYS=30

# ── Payouts ───────────────────────────────────────────────────────────────────
# Minimum payout threshold in KZT
PAYOUT_MIN_THRESHOLD=5000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173 http://localhost:5174
